generator client {
    provider = "prisma-client"
    output   = "./generated"
}

datasource db {
    provider = "postgresql"
}

model CameraNode {
    id          Int        @id @default(autoincrement())
    locationTag String
    latitude    Float
    longitude   Float
    isActive    Boolean    @default(true)
    incidents   Incident[]
    topic       String     @default("nws7D1IJ/sa/ep/#")

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

enum IncidentStatus {
    UNHANDLED
    DISPATCHED
    RESOLVED
    FALSE_ALARM
}

model Incident {
    id       String     @id @default(uuid())
    cameraId Int
    camera   CameraNode @relation(fields: [cameraId], references: [id])

    agencyId String?
    agency   EmergencyAgency? @relation(fields: [agencyId], references: [id])

    severity   Int
    confidence Int
    imageUrl   String
    status     IncidentStatus @default(UNHANDLED)
    topic      String         @default("nws7D1IJ/sa/ep/#")
    location   String         @default("N/A")

    detectedAt   DateTime  @default(now())
    dispatchedAt DateTime?
    resolvedAt   DateTime?
    notes        String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model EmergencyAgency {
    id        String @id @default(uuid())
    name      String
    vacancies Int
    topic     String @default("nws7D1IJ/sa/ep/#")

    incidents Incident[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}
